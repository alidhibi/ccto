{
  "name": "ccto",
  "version": "0.1.0",
  "private": true,
  "description": "Claude Code Token Optimizer — reduce token usage by 60–80% with local semantic indexing and MCP tools",
  "license": "MIT",
  "author": "alidhibi",
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=9.0.0"
  },
  "packageManager": "pnpm@9.15.0",
  "scripts": {
    "build": "pnpm -r build",
    "dev": "pnpm -r --parallel dev",
    "test": "vitest run",
    "test:watch": "vitest watch",
    "lint": "biome lint . --write",
    "format": "biome format . --write",
    "check": "biome check . --write",
    "typecheck": "pnpm -r typecheck",
    "clean": "pnpm -r clean"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.4",
    "tsup": "^8.3.5",
    "typescript": "^5.7.3",
    "vitest": "^2.1.8"
  }
}
